# ============================================================
#  Maahi Operator — environment
# ============================================================
# Copy to `.env` (gitignored) and fill in what you use. Maahi runs with
# ZERO of these set — every connector degrades to "not configured" — and
# lights up as you add keys. Load it with:  set -a; . ./.env; set +a
# (or use `bash run_operator.sh`, which sources .env automatically).

# ---- The brain (required for chat + brief synthesis) ----
ANTHROPIC_API_KEY=                 # https://console.anthropic.com/settings/keys

# ---- Command-center ----
MAAHI_OPERATOR_TOKEN=              # optional: require this bearer token on /api/*
MAAHI_OPERATOR_HOST=127.0.0.1      # 0.0.0.0 to expose on a server
MAAHI_OPERATOR_PORT=7777
MAAHI_AUTONOMY=act_report          # suggest | act_report | autopilot

# ============================================================
#  Business stack — set only what you want Maahi to reach
# ============================================================

# ---- CRM & deals ----
ZOHO_CRM_ACCESS_TOKEN=             # Zoho OAuth (scope ZohoCRM.modules.ALL)
ZOHO_CRM_API_DOMAIN=https://www.zohoapis.com

# ---- Comms ----
GMAIL_ACCESS_TOKEN=                # Google OAuth, scope gmail.modify (~1h expiry)
NOTION_TOKEN=                      # https://www.notion.so/my-integrations
GDRIVE_ACCESS_TOKEN=               # Google OAuth, scope drive (~1h expiry)

# ---- Marketing & growth ----
META_ACCESS_TOKEN=                 # Meta Graph API, scopes ads_read, ads_management
META_AD_ACCOUNT_ID=                # e.g. 1234567890 (act_ prefix optional)
WEBFLOW_API_TOKEN=                 # Webflow site settings -> Apps & integrations

# ---- Build & ship ----
GITHUB_TOKEN=                      # fine-grained PAT (repo + pull-request)
GITHUB_OWNER=                      # optional default owner for bare repo names
VERCEL_TOKEN=                      # https://vercel.com/account/tokens
VERCEL_TEAM_ID=                    # optional
SUPABASE_ACCESS_TOKEN=             # https://supabase.com/dashboard/account/tokens
CLOUDFLARE_API_TOKEN=              # https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_ACCOUNT_ID=             # optional

# ---- Generic MCP servers (reach any MCP endpoint) ----
# JSON list of {name,url,token}. Lets Maahi call any remote MCP server.
MAAHI_MCP_SERVERS=

# ---- Optional overrides ----
# MAAHI_MODEL=claude-opus-4-8
# MAAHI_FAST_MODEL=claude-sonnet-4-6
# MAAHI_VENTURES=Finanshels,BiggDate,Soulmap
# MAAHI_TIMEZONE=Asia/Dubai
