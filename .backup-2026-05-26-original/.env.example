# Copy this file to .env and fill values

# ─── LLM: Claude (primary brain — get key at https://console.anthropic.com) ──
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_HAIKU_MODEL=claude-haiku-4-5

# ─── LLM: Gemini (fallback + image generation) ────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ─── Embeddings (Voyage AI — get key at https://dash.voyageai.com) ───
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3-large

# ─── Google (Search + OAuth Gmail/Calendar) ───────────────────
GOOGLE_SEARCH_KEY=
GOOGLE_SEARCH_CX=
GMAIL_USER=
GMAIL_APP_PASSWORD=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8787/api/auth/google/callback

# ─── Voice STT (Whisper via OpenAI — get key at https://platform.openai.com) ──
OPENAI_API_KEY=

# ─── Voice TTS (ElevenLabs — get key at https://elevenlabs.io) ──
# Default voice is "Rachel" (21m00Tcm4TlvDq8ikWAM). Browse voices at elevenlabs.io/voice-library
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL=eleven_turbo_v2_5

# ─── Telegram (mobile reach — create bot via @BotFather) ──────
# 1. Message @BotFather on Telegram, run /newbot, get the token
# 2. Message @userinfobot to find your Telegram user ID
# 3. Set both below; leave TELEGRAM_ALLOWED_IDS empty to disable bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_IDS=

# ─── Server ───────────────────────────────────────────────────
PORT=8787
ALLOWED_ORIGINS=http://localhost:8787,http://127.0.0.1:8787
